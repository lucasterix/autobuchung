# Default-Tenant, falls Request keinen X-Tenant-Header schickt
BANK_DEFAULT_TENANT=A

# === Tenant A ===
A_BANK_API_KEY=
A_PATTI_BASE=https://patti.app
A_PATTI_EMAIL=
A_PATTI_PASSWORD=
A_PATTI_HTTP_TIMEOUT=20
A_GSHEET_ID=
A_GSHEET_SOURCE_TAB=Transactions
A_GSHEET_REVIEW_TAB=AutoBuchung
A_GOOGLE_APPLICATION_CREDENTIALS=/opt/autobuchung/keys/google-service-account.json

# === Tenant B ===
B_BANK_API_KEY=
B_PATTI_BASE=https://patti.app
B_PATTI_EMAIL=
B_PATTI_PASSWORD=
B_PATTI_HTTP_TIMEOUT=20
B_GSHEET_ID=
B_GSHEET_SOURCE_TAB=Transactions
B_GSHEET_REVIEW_TAB=AutoBuchung
B_GOOGLE_APPLICATION_CREDENTIALS=/opt/autobuchung/keys/google-service-account.json
